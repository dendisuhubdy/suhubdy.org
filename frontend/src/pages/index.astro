---
import Layout from '../layouts/Layout.astro';
import { getTeachings, downloadUrl, formatFileSize, categoryLabel } from '../lib/api';

const teachings = await getTeachings();

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  const day = d.getDate();
  const month = d.toLocaleDateString('en-US', { month: 'short' });
  const year = d.getFullYear();
  return `${day} ${month}, ${year}`;
}
---

<Layout title="Suhubdy">
  {teachings.length === 0 ? (
    <p class="empty">No posts yet.</p>
  ) : (
    <>
      <section class="section">
        <h2 class="section-title">Newest</h2>
        <ul class="post-list">
          {teachings.map((t) => (
            <li class="post-item">
              <div class="post-meta">
                <span class="date">{t.date_published ? formatDate(t.date_published) : ''}</span>
                <span class="tag">{categoryLabel(t.category)}</span>
              </div>
              <h3 class="post-title">{t.title}</h3>
              {t.description && <p class="post-desc">{t.description}</p>}
              {t.file && (
                <a href={downloadUrl(t.file.id)} class="attachment">
                  {t.file.filename_download} <span class="filesize">({formatFileSize(t.file.filesize)})</span>
                </a>
              )}
            </li>
          ))}
        </ul>
      </section>
    </>
  )}
</Layout>

<style>
  .empty {
    color: #999;
    font-style: italic;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #999;
    margin-bottom: 1.2rem;
  }

  .post-list {
    list-style: none;
  }

  .post-item {
    margin-bottom: 1.8rem;
    padding-bottom: 1.8rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.3rem;
  }

  .date {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-size: 0.78rem;
    color: #999;
  }

  .tag {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #aaa;
    background: #f5f5f5;
    padding: 0.1rem 0.45rem;
    border-radius: 2px;
  }

  .post-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #111;
    line-height: 1.4;
    margin-bottom: 0.3rem;
  }

  .post-desc {
    font-size: 0.92rem;
    color: #555;
    line-height: 1.65;
    margin-bottom: 0.6rem;
  }

  .attachment {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-size: 0.78rem;
    color: #555;
    text-decoration: none;
    border-bottom: 1px dashed #ccc;
    padding-bottom: 1px;
  }

  .attachment:hover {
    color: #111;
    border-bottom-color: #111;
  }

  .filesize {
    color: #aaa;
  }
</style>
