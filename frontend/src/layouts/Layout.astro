---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <div class="container">
      <header>
        <h1 class="site-title"><a href="/">Prof. Ir. Suhubdy Ph.D</a></h1>
        <p class="site-desc">Teachings and Writings</p>
        <nav>
          <a href="/">Posts</a>
          <a href="/">Tags</a>
          <a href="/">About</a>
          <a href="/">Archives</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <p>&copy; {new Date().getFullYear()} Suhubdy. All rights reserved.</p>
      </footer>
    </div>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: Georgia, 'Times New Roman', 'Noto Serif', serif;
    color: #333;
    background: #fff;
    font-size: 17px;
    line-height: 1.75;
  }

  .container {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  header {
    padding: 2.5rem 0 1.5rem;
    border-bottom: 1px solid #ddd;
    margin-bottom: 2rem;
  }

  .site-title {
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 0.1rem;
  }

  .site-title a {
    color: #111;
    text-decoration: none;
  }

  .site-desc {
    color: #777;
    font-size: 0.95rem;
    font-style: italic;
    margin-bottom: 1rem;
  }

  nav {
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-size: 0.82rem;
    color: #555;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  nav a:hover {
    color: #000;
  }

  main {
    min-height: 60vh;
    padding-bottom: 2rem;
  }

  footer {
    border-top: 1px solid #ddd;
    padding: 1.5rem 0;
    color: #aaa;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-size: 0.72rem;
  }
</style>
